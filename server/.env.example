# Server configuration. Copy to .env.local for development.

# Network
PORT=3000
HOSTNAME=0.0.0.0

# Data
DATA_DIR=./.data

# Auth — both required. Generate with: openssl rand -hex 32
ADMIN_TOKEN=replace-with-a-long-random-string
PLAYER_TOKEN=replace-with-a-long-random-string

# AI — OpenAI key required for the Compendium AI chat feature
OPENAI_API_KEY=sk-replace-with-your-key
# OPENAI_MODEL=gpt-5.4-mini  # default — good balance of speed/cost/quality
#                               options (cheapest→best):
#                               gpt-5.4-nano | gpt-5.4-mini | gpt-5.4 | gpt-5.4-pro
