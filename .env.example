# Owner-only config — copy to .env and fill in.
# Never commit .env to git.

# ─── Syncthing (main branch) ─────────────────────────────────────────────────
RAILWAY_URL=https://your-syncthing-app.up.railway.app
RAILWAY_API_KEY=your-stguiapikey-here
RAILWAY_DEVICE_ID=fill-in-after-init-railway
FOLDER_ID=the-compendium
VAULT_PATH=/mnt/c/Users/alexg/Documents/dnd/The-Compendium

# ─── CouchDB / LiveSync (livesync-couchdb branch) ────────────────────────────
# These match Railway's COUCHDB_USER / COUCHDB_PASSWORD env vars, plus the
# public domain Railway generated for the service.
COUCHDB_URL=https://your-couchdb-app.up.railway.app
COUCHDB_USER=admin
COUCHDB_PASSWORD=choose-a-strong-random-string
COUCHDB_DBNAME=vault
